[Unit]
Description=Postfix Policy Service
After=network.target

[Service]
Type=simple
DynamicUser=true
ReadOnlyPaths=/etc/postfix-policy

ExecStart=/usr/local/bin/postfixlimit
# ExecStart=/root/.local/bin/postfixlimit

StateDirectory=postfixlimit
StateDirectoryMode=0755
LogsDirectory=postfixlimit

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true

Restart=on-failure
RestartSec=5s

[Install]
WantedBy=multi-user.target
